generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Phase 0: 最小表，仅用于验证数据库连接
// 完整数据模型将在 Phase 2 建立
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
