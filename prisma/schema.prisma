generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums — Phase 2 Core
// ============================================================

enum Role {
  admin
  leader
  hrbp
  recruiter
  business_owner
  interviewer
}

enum ApplicationStage {
  sourced
  hr_screen
  business_screen
  first_interview
  second_interview
  final_interview
  offer_risk
  pre_onboarding
  hired
  rejected
  withdrawn
  closed
}

enum InterviewRound {
  hr_initial
  business_first
  business_second
  ceo_final
  cross_function
}

enum OverallRecommendation {
  STRONG_HIRE
  HIRE
  HOLD
  NO_HIRE
  STRONG_NO_HIRE
}

enum OfferRiskType {
  SALARY_GAP
  COMPETING_OFFER
  DECISION_DELAY
  START_DATE_UNCERTAIN
  COMMITMENT_UNRESOLVED
  PRE_ONBOARDING_SILENCE
  EXPECTATION_MISMATCH
}

enum ActionSignal {
  LOW_EFFECTIVE_CANDIDATES
  STALLED_HR_SCREEN
  STALLED_BUSINESS_SCREEN
  FEEDBACK_OVERDUE
  EVIDENCE_INSUFFICIENT
  SCORE_INCONSISTENT
  CALIBRATION_NEEDED
  CANDIDATE_REDIRECT
  OFFER_RISK_HIGH
  COMMITMENT_OVERDUE
}

enum AiAnalysisType {
  resume_analysis
  candidate_recommendation
  interview_performance
  interviewer_quality
  job_bottleneck
  ai_qa
}

enum ReportType {
  weekly_recruiting_review
  job_review
  department_review
}

enum BusinessDecision {
  PASS
  REJECT
  HOLD
  REDIRECT
}

enum BusinessReasonCode {
  EXPERIENCE_MISMATCH
  INDUSTRY_MISMATCH
  LEVEL_TOO_LOW
  LEVEL_TOO_HIGH
  SALARY_MISMATCH
  MOTIVATION_RISK
  STABILITY_RISK
  COMMUNICATION_RISK
  PROFILE_NOT_CLEAR
  OTHER
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum CommitmentType {
  SALARY_REVIEW
  TEAM_RESOURCE
  ONBOARDING_SUPPORT
  ROLE_SCOPE
  PROBATION_TRANSFER
}

enum ReportStatus {
  draft
  confirmed
  archived
}

// ============================================================
// Models — Phase 2 Core
// ============================================================

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  parentId  String?
  parent    Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[]  @relation("DepartmentHierarchy")
  users     User[]
  jobs      Job[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         Role     @default(interviewer)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedJobs        Job[]             @relation("JobOwner")
  businessJobs     Job[]             @relation("JobBusinessOwner")
  applications     Application[]     @relation("ApplicationOwner")
  interviews       Interview[]       @relation("Interviewer")
  interviewFeedbacks InterviewFeedback[] @relation("FeedbackInterviewer")
  businessFeedbacks BusinessFeedback[]
  ownedActions     ActionItem[]      @relation("ActionOwner")
  createdActions   ActionItem[]      @relation("ActionCreator")
  offerRisks       OfferRisk[]       @relation("OfferRiskOwner")
  activityLogs     ActivityLog[]
  aiAnalysisLogs   AiAnalysisLog[]

  @@map("users")
}

model Job {
  id              String           @id @default(cuid())
  jobCode         String?          @unique @map("job_code")
  title           String
  brandLine       String?          @map("brand_line")
  departmentId    String
  department      Department       @relation(fields: [departmentId], references: [id])
  level           String?
  status          String           @default("open")
  priority        String           @default("normal")
  ownerId         String
  owner           User             @relation("JobOwner", fields: [ownerId], references: [id])
  businessOwnerId String?
  businessOwner   User?            @relation("JobBusinessOwner", fields: [businessOwnerId], references: [id])
  location        String?
  headcount       Int              @default(1)
  jdText          String?
  profileSummary  String?
  mustHave        Json?
  niceToHave      Json?
  targetCompanies Json?            @map("target_companies")
  interviewFocus  Json?            @map("interview_focus")
  salaryMin       Int?
  salaryMax       Int?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  applications         Application[]
  businessFeedbacks    BusinessFeedback[]
  profileCalibrations  ProfileCalibration[]
  actions              ActionItem[]

  @@map("jobs")
}

model Candidate {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  source          String?
  currentCompany  String?  @map("current_company")
  currentTitle    String?  @map("current_title")
  resumeSummary   String?  @map("resume_summary")
  tags            String[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  applications Application[]
  actions      ActionItem[]

  @@map("candidates")
}

model Application {
  id              String           @id @default(cuid())
  jobId           String
  job             Job              @relation(fields: [jobId], references: [id])
  candidateId     String
  candidate       Candidate        @relation(fields: [candidateId], references: [id])
  stage           ApplicationStage @default(sourced)
  status          String           @default("active")
  ownerId         String?
  owner           User?            @relation("ApplicationOwner", fields: [ownerId], references: [id])
  source          String?
  fitScore        Int?             @map("fit_score")
  lastActivityAt  DateTime?        @map("last_activity_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  interviews       Interview[]
  offerRisks       OfferRisk[]
  offerCommitments OfferCommitment[]
  actionItems      ActionItem[]

  @@map("applications")
}

model Interview {
  id            String         @id @default(cuid())
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id])
  round         InterviewRound
  interviewerId String
  interviewer   User           @relation("Interviewer", fields: [interviewerId], references: [id])
  scheduledAt   DateTime?      @map("scheduled_at")
  completedAt   DateTime?      @map("completed_at")
  status        String         @default("scheduled")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  feedbacks InterviewFeedback[]
  actions   ActionItem[]

  @@map("interviews")
}

model InterviewFeedback {
  id                    String               @id @default(cuid())
  interviewId           String
  interview             Interview            @relation(fields: [interviewId], references: [id])
  interviewerId         String               @map("interviewer_id")
  interviewer           User                 @relation("FeedbackInterviewer", fields: [interviewerId], references: [id])
  overallRecommendation OverallRecommendation? @map("overall_recommendation")
  scores                Json?
  evidenceText          String?              @map("evidence_text")
  riskNotes             String?              @map("risk_notes")
  suggestedFollowUpQuestions String[]             @map("suggested_follow_up_questions")
  feedbackQualityScore  Int?                 @map("feedback_quality_score")
  qualityLevel          String?              @map("quality_level")
  riskSignals           Json?                @map("risk_signals")
  submittedAt           DateTime?            @map("submitted_at")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  @@map("interview_feedbacks")
}

model BusinessFeedback {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id])
  applicationId String?
  reviewerId    String
  reviewer      User     @relation(fields: [reviewerId], references: [id])
  decision      String
  reasonCode    String?  @map("reason_code")
  reasonText    String?  @map("reason_text")
  evidence      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("business_feedbacks")
}

model ProfileCalibration {
  id                String    @id @default(cuid())
  jobId             String
  job               Job       @relation(fields: [jobId], references: [id])
  beforeSnapshot    Json?     @map("before_snapshot")
  afterSnapshot     Json?     @map("after_snapshot")
  sourceFeedbackIds String[]  @map("source_feedback_ids")
  calibrationReason String?   @map("calibration_reason")
  createdBy         String
  status            String    @default("draft")
  confirmedAt       DateTime? @map("confirmed_at")
  confirmedBy       String?   @map("confirmed_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("profile_calibrations")
}

model ActionItem {
  id              String      @id @default(cuid())
  title           String
  description     String?
  category        String      @default("manual")
  priority        String      @default("medium")
  status          String      @default("open")

  ownerId         String?
  owner           User?       @relation("ActionOwner", fields: [ownerId], references: [id])
  createdById     String
  createdBy       User        @relation("ActionCreator", fields: [createdById], references: [id])

  jobId           String?
  job             Job?        @relation(fields: [jobId], references: [id])
  candidateId     String?
  candidate       Candidate?  @relation(fields: [candidateId], references: [id])
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id])
  interviewId     String?
  interview       Interview?  @relation(fields: [interviewId], references: [id])
  feedbackId      String?

  sourceType      String      @map("source_type")
  sourceRefId     String?     @map("source_ref_id")
  sourceSummary   String?     @map("source_summary")

  dueAt           DateTime?   @map("due_at")
  resolvedAt      DateTime?   @map("resolved_at")
  resolvedById    String?
  resolutionNote  String?     @map("resolution_note")
  dismissedReason String?    @map("dismissed_reason")

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("action_items")
}

model OfferRisk {
  id            String        @id @default(cuid())
  applicationId String
  application   Application   @relation(fields: [applicationId], references: [id])
  riskType      OfferRiskType @map("risk_type")
  level         String        @default("medium")
  description   String?
  ownerId       String?
  owner         User?         @relation("OfferRiskOwner", fields: [ownerId], references: [id])
  status        String        @default("open")
  dueAt         DateTime?     @map("due_at")
  resolvedAt    DateTime?     @map("resolved_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("offer_risks")
}

model OfferCommitment {
  id             String   @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id])
  commitmentType String   @map("commitment_type")
  description    String?
  ownerId        String?
  status         String   @default("pending")
  dueAt          DateTime? @map("due_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("offer_commitments")
}

model AiAnalysisLog {
  id                     String         @id @default(cuid())
  analysisType           AiAnalysisType @map("analysis_type")
  resourceType           String         @map("resource_type")
  resourceId             String         @map("resource_id")
  userId                 String
  user                   User           @relation(fields: [userId], references: [id])
  inputHash              String?        @map("input_hash")
  promptName             String?        @map("prompt_name")
  promptVersion          String?        @map("prompt_version")
  provider               String?
  model                  String?
  confidence             Float?
  outputJson             Json?          @map("output_json")
  sanitizedInputSnapshot Json?          @map("sanitized_input_snapshot")
  isFallback             Boolean        @default(false) @map("is_fallback")
  isConfirmed            Boolean        @default(false) @map("is_confirmed")
  confirmedBy            String?        @map("confirmed_by")
  confirmedAt            DateTime?      @map("confirmed_at")
  createdAt              DateTime       @default(now()) @map("created_at")

  @@map("ai_analysis_logs")
}

model ReportSnapshot {
  id               String       @id @default(cuid())
  reportType       ReportType   @map("report_type")
  scopeType        String       @map("scope_type")
  scopeId          String?      @map("scope_id")
  periodStart      DateTime     @map("period_start")
  periodEnd        DateTime     @map("period_end")
  title            String
  status           String       @default("draft")
  metricsSnapshot  Json?      @map("metrics_snapshot")
  sectionsSnapshot Json?      @map("sections_snapshot")
  insightSnapshot  Json?      @map("insight_snapshot")
  generatedBy      String?
  confirmedBy      String?    @map("confirmed_by")
  confirmedAt      DateTime?  @map("confirmed_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@map("report_snapshots")
}

model ImportBatch {
  id                 String   @id @default(cuid())
  fileName           String   @map("file_name")
  fileType           String   @map("file_type")
  status             String   @default("pending")
  totalRows          Int      @default(0) @map("total_rows")
  validRows          Int      @default(0) @map("valid_rows")
  errorRows          Int      @default(0) @map("error_rows")
  mappingSnapshot    Json?    @map("mapping_snapshot")
  validationSnapshot Json?    @map("validation_snapshot")
  createdBy          String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("import_batches")
}

model ActivityLog {
  id           String   @id @default(cuid())
  actorId      String   @map("actor_id")
  actor        User     @relation(fields: [actorId], references: [id])
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  detail       Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}

model AIInsight {
  id                String    @id @default(cuid())
  objectType        String
  objectId          String
  insightType       String
  title             String
  summary           String
  suggestedAction   String?
  riskLevel         String?
  generatedBy       String
  provider          String?
  model             String?
  promptVersion     String?
  confidence        Float?
  humanReviewStatus String    @default("pending")
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  evidences         AIEvidence[]
  reviews           AIHumanReview[]

  @@map("ai_insights")
}

model AIEvidence {
  id          String    @id @default(cuid())
  aiInsightId String
  aiInsight   AIInsight @relation(fields: [aiInsightId], references: [id])
  sourceType  String
  sourceId    String?
  sourceLabel String
  summary     String
  quote       String?
  metricName  String?
  metricValue String?
  createdAt   DateTime  @default(now())

  @@map("ai_evidences")
}

model AIPromptTemplate {
  id                 String   @id @default(cuid())
  key                String   @unique
  name               String
  objectType         String
  promptVersion      String
  systemPrompt       String
  userPromptTemplate String
  outputSchema       String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ai_prompt_templates")
}

model AICallLog {
  id               String   @id @default(cuid())
  provider         String
  model            String
  objectType       String
  objectId         String?
  promptVersion    String
  requestHash      String
  status           String
  latencyMs        Int?
  tokenUsageInput  Int?
  tokenUsageOutput Int?
  errorCode        String?
  errorMessage     String?
  createdById      String?
  createdAt        DateTime @default(now())

  @@map("ai_call_logs")
}

model AIHumanReview {
  id                     String    @id @default(cuid())
  aiInsightId            String
  aiInsight              AIInsight @relation(fields: [aiInsightId], references: [id])
  reviewerId             String
  status                 String
  reviewNote             String?
  editedSummary          String?
  editedSuggestedAction  String?
  createdAt              DateTime  @default(now())

  @@map("ai_human_reviews")
}

model DataSource {
  id            String   @id @default(cuid())
  sourceType    String   // upload / feishu_link / moka_link / external_url
  sourceSystem  String   // local / feishu / moka / external
  fileName      String?
  fileMimeType  String?
  fileSize      Int?
  fileUrl       String?
  externalUrl   String?
  externalId    String?
  objectType    String?
  objectId      String?
  usageType     String?
  parseStatus   String   @default("pending")
  parseError    String?
  uploadedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chunks        DataSourceChunk[]
  parseJobs     DataSourceParseJob[]
  links         DataSourceLink[]

  @@map("data_sources")
}

model DataSourceChunk {
  id            String   @id @default(cuid())
  dataSourceId  String
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id])
  chunkIndex    Int
  contentText   String?
  contentSummary String?
  tokenCount    Int?
  metadataJson  String?
  createdAt     DateTime @default(now())

  @@map("data_source_chunks")
}

model DataSourceParseJob {
  id            String    @id @default(cuid())
  dataSourceId  String
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id])
  jobStatus     String    @default("pending")
  parserType    String?
  startedAt     DateTime?
  finishedAt    DateTime?
  errorCode     String?
  errorMessage  String?
  createdAt     DateTime  @default(now())

  @@map("data_source_parse_jobs")
}

model DataSourceLink {
  id            String   @id @default(cuid())
  dataSourceId  String
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id])
  objectType    String
  objectId      String
  createdAt     DateTime @default(now())

  @@map("data_source_links")
}

model IntegrationConnection {
  id                String    @id @default(cuid())
  provider          String    @unique
  status            String    @default("not_configured")
  displayName       String?
  mode              String    @default("ai_provider")
  isWritebackEnabled Boolean  @default(false) @map("is_writeback_enabled")
  lastCheckedAt     DateTime?
  lastSuccessAt     DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("integration_connections")
}

model IntegrationCredentialMeta {
  id             String    @id @default(cuid())
  provider       String    @unique
  configured     Boolean   @default(false)
  maskedKeyPreview String? @map("masked_key_preview")
  secretStorage  String    @default("none") @map("secret_storage")
  lastRotatedAt  DateTime? @map("last_rotated_at")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("integration_credential_meta")
}

model IntegrationRunLog {
  id           String   @id @default(cuid())
  provider     String
  runType      String   @map("run_type")
  status       String
  latencyMs    Int?     @map("latency_ms")
  requestId    String?  @map("request_id")
  errorCode    String?  @map("error_code")
  errorMessage String?  @map("error_message")
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now())

  @@map("integration_run_logs")
}

model ExternalObjectMapping {
  id                String    @id @default(cuid())
  provider          String
  externalObjectType String   @map("external_object_type")
  externalId        String?   @map("external_id")
  externalUrl       String?   @map("external_url")
  objectType        String    @map("object_type")
  objectId          String?   @map("object_id")
  syncStatus        String    @default("link_only") @map("sync_status")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdById       String?   @map("created_by_id")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("external_object_mappings")
}
model KnowledgeCollection {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  visibility  String   @default("global")
  allowedRoles String?
  status      String   @default("active")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  documents   KnowledgeDocument[]
  @@map("knowledge_collections")
}

model KnowledgeDocument {
  id            String   @id @default(cuid())
  collectionId  String
  collection    KnowledgeCollection @relation(fields: [collectionId], references: [id])
  dataSourceId  String   @unique
  title         String
  sourceType    String
  usageType     String?
  objectType    String?
  objectId      String?
  indexStatus   String   @default("pending")
  chunkCount    Int      @default(0)
  lastIndexedAt DateTime?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chunks        KnowledgeChunk[]
  indexJobs     KnowledgeIndexJob[]
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id                  String   @id @default(cuid())
  knowledgeDocumentId String
  knowledgeDocument   KnowledgeDocument @relation(fields: [knowledgeDocumentId], references: [id])
  dataSourceChunkId   String?
  chunkIndex          Int
  contentText         String?
  contentSummary      String?
  tags                String?
  tokenCount          Int?
  evidenceLevel       String   @default("unknown")
  embeddingStatus     String   @default("not_configured")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("knowledge_chunks")
}

model KnowledgeSearchLog {
  id            String   @id @default(cuid())
  query         String
  mode          String   @default("keyword")
  collectionKey String?
  objectType    String?
  objectId      String?
  userId        String?
  topK          Int      @default(5)
  resultCount   Int      @default(0)
  noEvidence    Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@map("knowledge_search_logs")
}

model KnowledgeAnswer {
  id                String   @id @default(cuid())
  question          String
  answer            String?
  answerStatus      String   @default("pending")
  generatedBy       String   @default("retrieval_only")
  provider          String?
  model             String?
  promptVersion     String?
  humanReviewStatus String   @default("pending")
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  citations         KnowledgeCitation[]
  @@map("knowledge_answers")
}

model KnowledgeCitation {
  id                String   @id @default(cuid())
  knowledgeAnswerId String
  knowledgeAnswer   KnowledgeAnswer @relation(fields: [knowledgeAnswerId], references: [id])
  knowledgeChunkId  String
  dataSourceId      String?
  dataSourceChunkId String?
  sourceLabel       String
  quote             String?
  summary           String?
  score             Float?
  createdAt         DateTime @default(now())
  @@map("knowledge_citations")
}

model KnowledgeIndexJob {
  id                  String    @id @default(cuid())
  dataSourceId        String
  knowledgeDocumentId String?
  knowledgeDocument   KnowledgeDocument? @relation(fields: [knowledgeDocumentId], references: [id])
  status              String    @default("pending")
  startedAt           DateTime?
  finishedAt          DateTime?
  errorCode           String?
  errorMessage        String?
  createdAt           DateTime  @default(now())
  @@map("knowledge_index_jobs")
}

// ============================================================
// Models — Phase 8.10 Audio/Video/Transcription Foundation
// ============================================================

model MediaAsset {
  id                   String   @id @default(cuid())
  dataSourceId         String?
  objectType           String
  objectId             String
  mediaType            String
  fileName             String
  mimeType             String?
  fileSize             Int?
  durationMs           Int?
  storageKey           String?
  storageUrl           String?
  transcriptionStatus  String   @default("none")
  uploadedById         String?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  transcriptionJobs    TranscriptionJob[]
  transcripts          Transcript[]

  @@map("media_assets")
}

model TranscriptionJob {
  id              String    @id @default(cuid())
  mediaAssetId    String
  mediaAsset      MediaAsset @relation(fields: [mediaAssetId], references: [id])
  provider        String    @default("not_configured")
  providerStatus  String    @default("pending")
  status          String    @default("pending")
  startedAt       DateTime?
  finishedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  createdById     String?
  createdAt       DateTime  @default(now()) @map("created_at")

  transcripts     Transcript[]

  @@map("transcription_jobs")
}

model Transcript {
  id                  String   @id @default(cuid())
  mediaAssetId        String
  mediaAsset          MediaAsset @relation(fields: [mediaAssetId], references: [id])
  transcriptionJobId  String?
  transcriptionJob    TranscriptionJob? @relation(fields: [transcriptionJobId], references: [id])
  source              String   @default("asr")
  language            String   @default("zh-CN")
  reviewStatus        String   @default("pending")
  redactionStatus     String   @default("none")
  segmentCount        Int      @default(0)
  createdById         String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  segments            TranscriptSegment[]
  analyses            TranscriptAnalysis[]
  citations           TranscriptCitation[]

  @@map("transcripts")
}

model TranscriptSegment {
  id            String   @id @default(cuid())
  transcriptId  String
  transcript    Transcript @relation(fields: [transcriptId], references: [id])
  segmentIndex  Int
  speakerLabel  String?
  startMs       Int?
  endMs         Int?
  text          String
  redactedText  String?
  evidenceLevel String   @default("raw")
  isAiUsable    Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  citations     TranscriptCitation[]

  @@map("transcript_segments")
}

model TranscriptAnalysis {
  id                  String   @id @default(cuid())
  transcriptId        String
  transcript          Transcript @relation(fields: [transcriptId], references: [id])
  analysisType        String
  generatedBy         String   @default("system_rule")
  provider            String?
  model               String?
  promptVersion       String?
  summary             String?
  riskSignals         String?
  suggestedFollowUps  String?
  humanReviewStatus   String   @default("pending")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("transcript_analyses")
}

model TranscriptCitation {
  id                String   @id @default(cuid())
  aiInsightId       String?
  knowledgeAnswerId  String?
  transcriptId      String
  transcript        Transcript @relation(fields: [transcriptId], references: [id])
  segmentId         String?
  segment           TranscriptSegment? @relation(fields: [segmentId], references: [id])
  quote             String?
  timeRange         String?
  sourceLabel       String
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("transcript_citations")
}

// ============================================================
// Models — Speech & Communication Analysis
// ============================================================

model SpeechMetric {
  id                  String   @id @default(cuid())
  transcriptId        String   @map("transcript_id")
  metricKey           String   @map("metric_key")
  metricValue         Float    @map("metric_value")
  speakerRole         String?  @map("speaker_role")
  evidenceSegmentIds  String?  @map("evidence_segment_ids")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("speech_metrics")
}

model CommunicationAnalysis {
  id                String   @id @default(cuid())
  transcriptId      String   @map("transcript_id")
  analysisType      String   @map("analysis_type")
  title             String
  summary           String?
  riskLevel         String?  @map("risk_level")
  generatedBy       String   @default("system_rule") @map("generated_by")
  provider          String?
  model             String?
  promptVersion     String?  @map("prompt_version")
  humanReviewStatus String   @default("pending") @map("human_review_status")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  evidences         CommunicationEvidence[]
  reviews           CommunicationReview[]

  @@map("communication_analyses")
}

model CommunicationEvidence {
  id                  String   @id @default(cuid())
  analysisId          String   @map("analysis_id")
  analysis            CommunicationAnalysis @relation(fields: [analysisId], references: [id])
  transcriptSegmentId String?  @map("transcript_segment_id")
  quote               String?
  startMs             Int?     @map("start_ms")
  endMs               Int?     @map("end_ms")
  speakerRole         String?  @map("speaker_role")
  reason              String?
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("communication_evidences")
}

model CommunicationReview {
  id              String   @id @default(cuid())
  analysisId      String   @map("analysis_id")
  analysis        CommunicationAnalysis @relation(fields: [analysisId], references: [id])
  reviewerId      String   @map("reviewer_id")
  status          String
  reviewNote      String?  @map("review_note")
  editedSummary   String?  @map("edited_summary")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("communication_reviews")
}

// ============================================================
// Phase 8.11 — AI Copilot Deepening
// ============================================================

model AICopilotSession {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  role        String
  moduleKey   String   @map("module_key")
  objectType  String   @map("object_type")
  objectId    String   @map("object_id")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages    AICopilotMessage[]
  contextRefs AICopilotContextRef[]

  @@index([userId, status])
  @@index([objectType, objectId])
  @@map("ai_copilot_sessions")
}

model AICopilotMessage {
  id                String   @id @default(cuid())
  sessionId         String   @map("session_id")
  session           AICopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role              String
  content           String
  answerStatus      String?  @map("answer_status")
  provider          String?
  model             String?
  promptVersion     String?  @map("prompt_version")
  humanReviewStatus String   @default("pending") @map("human_review_status")
  createdAt         DateTime @default(now()) @map("created_at")

  contextRefs       AICopilotContextRef[]
  draftActions      AIDraftAction[]
  reviewEvents      AIReviewEvent[]

  @@index([sessionId, createdAt])
  @@map("ai_copilot_messages")
}

model AICopilotContextRef {
  id              String   @id @default(cuid())
  sessionId       String   @map("session_id")
  session         AICopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messageId       String?  @map("message_id")
  message         AICopilotMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  refType         String   @map("ref_type")
  refId           String   @map("ref_id")
  objectType      String   @map("object_type")
  objectId        String   @map("object_id")
  sourceLabel     String   @map("source_label")
  excerpt         String?
  redactionStatus String   @default("applied") @map("redaction_status")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([messageId])
  @@map("ai_copilot_context_refs")
}

model AIDraftAction {
  id                String    @id @default(cuid())
  sourceMessageId   String    @map("source_message_id")
  sourceMessage     AICopilotMessage @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  category          String    @default("ai_suggestion")
  priority          String    @default("medium")
  suggestedOwnerId  String?   @map("suggested_owner_id")
  dueAt             DateTime? @map("due_at")
  status            String    @default("draft")
  confirmedActionId String?   @map("confirmed_action_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([sourceMessageId])
  @@index([status])
  @@map("ai_draft_actions")
}

model AIReviewEvent {
  id            String   @id @default(cuid())
  messageId     String   @map("message_id")
  message       AICopilotMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reviewStatus  String   @map("review_status")
  editedContent String?  @map("edited_content")
  reviewedById  String   @map("reviewed_by_id")
  reviewNote    String?  @map("review_note")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([messageId])
  @@map("ai_review_events")
}
